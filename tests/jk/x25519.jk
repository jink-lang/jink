import from std.crypto.x25519 { x25519, x25519_base };
import from std.testing { check_hex, from_hex };
import from std.mem.raw { alloc };
import from jink.ext.libc { exit };

fun run() -> void {
  int fails = 0;

  // RFC 7748 5.2 test vector 1
  ptr scalar = alloc(32);
  ptr u = alloc(32);
  ptr out = alloc(32);
  from_hex("a546e36bf0527c9d3b16154b82465edd62144c0ac1fc5a18506a2244ba449ac4", scalar, 32);
  from_hex("e6db6867583030db3594c1a424b15f7c726624ec26b3353b10a903a6d0ab1c4c", u, 32);
  x25519(out, scalar, u);
  fails = fails + check_hex("x25519-scalarmult", out, 32,
    "c3da55379de9c6908e94ea4df28d084f32eccf03491c71f754b4075577a28552");

  // RFC 7748 6.1: Alice public = X25519(a, 9)
  ptr apriv = alloc(32);
  ptr apub = alloc(32);
  from_hex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a", apriv, 32);
  x25519_base(apub, apriv);
  fails = fails + check_hex("x25519-base", apub, 32,
    "8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a");

  exit(fails);
}

run();
