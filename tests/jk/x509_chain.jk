import from std.crypto.x509_chain { x509_chain_verify };
import from std.testing { check_int };
import from std.mem.raw { alloc };
import from jink.ext.libc { strlen, exit };

fun hexval(int ch) -> int {
  if (ch >= 97) { return ch - 87; }
  return ch - 48;
}
fun load(string h, ptr out) -> void {
  int n = strlen(h) / 2;
  int i = 0;
  while (i < n) {
    int hi = hexval(__ptr_read_byte(h, 2 * i));
    int lo = hexval(__ptr_read_byte(h, 2 * i + 1));
    __ptr_write_byte(out, i, (hi << 4) | lo);
    i = i + 1;
  }
}

fun run() -> void {
  int fails = 0;

  ptr leaf = alloc(1024);
  load("", leaf);

  ptr inter = alloc(1024);
  load("", inter);

  ptr root = alloc(1024);
  load("", root);

  ptr certs = alloc(16);
  __ptr_write_ptr(certs, 0, leaf);
  __ptr_write_ptr(certs, 1, inter);

  fails = fails + check_int("chain-valid",
    x509_chain_verify(certs, 2, root, "jink.test", "20300101000000"), 1);
  fails = fails + check_int("chain-wrong-host",
    x509_chain_verify(certs, 2, root, "evil.test", "20300101000000"), 0);
  fails = fails + check_int("chain-expired",
    x509_chain_verify(certs, 2, root, "jink.test", "20400101000000"), 0);

  int saved = __ptr_read_byte(leaf, 80);
  __ptr_write_byte(leaf, 80, saved ^ 1);
  fails = fails + check_int("chain-tampered-leaf",
    x509_chain_verify(certs, 2, root, "jink.test", "20300101000000"), 0);

  exit(fails);
}

run();
