import from std.crypto.x509 { x509_self_verify };
import from std.testing { check_int };
import from std.mem.raw { alloc };
import from jink.ext.libc { strlen, exit };

fun hexval(int ch) -> int {
  if (ch >= 97) { return ch - 87; }
  return ch - 48;
}
fun load(string h, ptr out) -> int {
  int n = strlen(h) / 2;
  int i = 0;
  while (i < n) {
    int hi = hexval(__ptr_read_byte(h, 2 * i));
    int lo = hexval(__ptr_read_byte(h, 2 * i + 1));
    __ptr_write_byte(out, i, (hi << 4) | lo);
    i = i + 1;
  }
  return n;
}

fun run() -> void {
  int fails = 0;

  string rsacert = "";
  ptr rbuf = alloc(2048);
  load(rsacert, rbuf);
  fails = fails + check_int("x509-rsa-self-verify", x509_self_verify(rbuf), 1);

  string eccert = "";
  ptr ebuf = alloc(1024);
  load(eccert, ebuf);
  fails = fails + check_int("x509-ecdsa-self-verify", x509_self_verify(ebuf), 1);

  // ECDSA-P384 self-signed (ecdsa-with-SHA384)
  string p384cert = "";
  ptr pbuf = alloc(1024);
  load(p384cert, pbuf);
  fails = fails + check_int("x509-p384-self-verify", x509_self_verify(pbuf), 1);

  int saved = __ptr_read_byte(rbuf, 100);
  __ptr_write_byte(rbuf, 100, saved ^ 1);
  fails = fails + check_int("x509-tampered-reject", x509_self_verify(rbuf), 0);

  exit(fails);
}

run();
