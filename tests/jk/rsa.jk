import from std.crypto.rsa { rsa_pkcs1_sha256_verify };
import from std.testing { check_int, from_hex };
import from std.mem.raw { alloc };
import from jink.ext.libc { strlen, exit };

fun run() -> void {
  int fails = 0;
  ptr n = alloc(256);
  from_hex("", n, 256);
  ptr sig = alloc(256);
  from_hex("", sig, 256);

  string msg = "Jink RSA test vector";
  fails = fails + check_int("rsa-verify-valid",
    rsa_pkcs1_sha256_verify(n, 256, 65537, sig, msg, strlen(msg)), 1);

  int saved = __ptr_read_byte(sig, 100);
  __ptr_write_byte(sig, 100, saved ^ 1);
  fails = fails + check_int("rsa-verify-tampered",
    rsa_pkcs1_sha256_verify(n, 256, 65537, sig, msg, strlen(msg)), 0);

  exit(fails);
}

run();
