import from std.net.tls_record { tls_protect, tls_unprotect };
import from std.testing { check_int, check_bytes };
import from std.mem.raw { alloc };
import from jink.ext.libc { strlen, exit };

fun run() -> void {
  int fails = 0;
  int i = 0;

  ptr key = alloc(32);
  i = 0; while (i < 32) { __ptr_write_byte(key, i, i); i = i + 1; }
  ptr iv = alloc(12);
  i = 0; while (i < 12) { __ptr_write_byte(iv, i, 0xA0 + i); i = i + 1; }

  string msg = "hello tls 1.3 record";
  int clen = strlen(msg);
  ptr rec = alloc(256);
  int reclen = tls_protect(key, iv, 0, msg, clen, 22, rec);

  ptr header = alloc(5);
  i = 0; while (i < 5) { __ptr_write_byte(header, i, __ptr_read_byte(rec, i)); i = i + 1; }
  int plen = reclen - 5;
  ptr payload = alloc(256);
  i = 0; while (i < plen) { __ptr_write_byte(payload, i, __ptr_read_byte(rec, 5 + i)); i = i + 1; }

  ptr content = alloc(256);
  ptr rtype = alloc(1);
  int got = tls_unprotect(key, iv, 0, header, payload, plen, content, rtype);
  fails = fails + check_int("record-content-len", got, clen);
  fails = fails + check_bytes("record-content", content, msg, clen);
  int rt = __ptr_read_byte(rtype, 0);
  fails = fails + check_int("record-type", rt, 22);

  // Flip a ciphertext byte -> authentication must fail
  int saved = __ptr_read_byte(payload, 0);
  __ptr_write_byte(payload, 0, saved ^ 1);
  int bad = tls_unprotect(key, iv, 0, header, payload, plen, content, rtype);
  fails = fails + check_int("record-tamper-rejected", bad, 0 - 1);

  exit(fails);
}

run();
